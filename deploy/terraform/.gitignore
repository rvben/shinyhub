# Terraform local state and caches - never commit these.

# Provider plugins + module cache, regenerated by `terraform init` (can be large).
**/.terraform/

# State files - may contain secrets; keep out of git.
*.tfstate
*.tfstate.*

# Crash logs and saved plans.
crash.log
crash.*.log
*.tfplan

# Local CLI config / credentials overrides.
.terraformrc
terraform.rc

# NOTE: .terraform.lock.hcl is intentionally NOT ignored - commit it so provider
# versions are pinned and reproducible (it is the provider dependency lock).
